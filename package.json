    "touch",
    "position",
    "coordinates",
    "hover",
    "press",
    "tap",
    "hooks",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinelink/react-cursor-position.git"
  },
  "bugs": {
    "url": "https://github.com/vinelink/react-cursor-position/issues"
  },
  "homepage": "https://github.com/vinelink/react-cursor-position#readme",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {

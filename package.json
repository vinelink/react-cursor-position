    "@storybook/addon-essentials": "^8.6.2",
    "@storybook/test": "^8.6.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "react": "^19.0.0",
    "storybook": "^8.6.2",
    "storybook-addon-rslib": "^1.0.0",
    "storybook-react-rsbuild": "^1.0.0",
    "typescript": "^5.7.3"
  },
